MERCHANT_EMAIL=
RESEND_API_KEY=

# 32 random bytes, base64-encoded. Used to sign admin JWTs (HS256).
# Generate with: head -c 32 /dev/urandom | base64
ADMIN_JWT_SECRET=
# 32 random bytes, base64-encoded. Used to encrypt admin TOTP secrets at rest.
# Generate with: head -c 32 /dev/urandom | base64
ADMIN_TOTP_ENCRYPTION_KEY=
